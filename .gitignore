# ============================================================================
# This repo commits the audit code (src/, scripts/, tests/), the digested result
# records under outputs/, and the result figures. Heavy/regenerable data, internal working notes, scratch run output, and
# superseded scripts stay out.
# ============================================================================

# --- internal working folders (kept locally, not committed) ---
00-build-plan/
01-target-catalogs/
02-methods-sbi-calibration/
03-domain-refs/
05-note/
docs/
configs/

# --- heavy / regenerable data (Li catalog on Zenodo, pulled XP spectra, grids) ---
data/

# --- internal working notes ---
RESULTS.md
PROGRESS.md

# --- superseded / scratch scripts (kept locally, not part of the public code) ---
scripts/run_p0_gonogo.py
scripts/run_catalog_audit.py
scripts/probe_groundtruth.py
scripts/build_groundtruth_enlarged.py
scripts/expand_groundtruth.py
scripts/run_precise_standalone.py
scripts/run_precise_all.sh

# --- unimplemented domain-layer stubs (the package ships only audit.py) ---
src/sbiwdms/classifier.py
src/sbiwdms/misspec.py
src/sbiwdms/models.py
src/sbiwdms/priors.py
src/sbiwdms/responses.py
src/sbiwdms/simulate.py

# --- Python / tooling junk ---
__pycache__/
*.pyc
.pytest_cache/
.venv/
*.egg-info/
build/
dist/
.ipynb_checkpoints/

# --- heavy ML artifacts (checkpoints, posteriors, arrays) ---
sbi-logs/
*.h5
*.pt
*.pkl
*.ckpt
*.npz

# --- figures: commit the PNGs, not the regenerated PDFs ---
figures/*.pdf

# ----------------------------------------------------------------------------
# Result records under outputs/: ignore everything, then re-include only the
# digested JSON records behind the README numbers. All scratch (per-seed part
# files, _cells, per-seed dumps, .err/.out/.log, derived CSVs, scratch .md,
# duplicate PNGs, superseded run records) stays out.
# ----------------------------------------------------------------------------
outputs/**
!outputs/
